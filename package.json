{
	"name": "meat-store",
	"version": "1.0.0",
	"private": true,
	"description": "Meat store ordering system",
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"dev:web": "npm run dev --workspace apps/web",
		"dev:api": "npm run start:dev --workspace apps/api",
		"dev": "concurrently \"npm run dev:web\" \"npm run dev:api\""
	},
	"devDependencies": {
		"concurrently": "9.2.1"
	}
}
